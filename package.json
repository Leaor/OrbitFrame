{
  "name": "orbframe",
  "version": "1.0.1",
  "description": "OrbitFrame — A futuristic screen capture and sharing toolkit",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.orbitframe.app",
    "productName": "OrbitFrame",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  },
  "keywords": ["screenshot", "screen-capture", "recording", "annotation", "upload"],
  "author": "OrbitFrame",
  "license": "MIT",
  "dependencies": {
    "electron-store": "^8.1.0",
    "fluent-ffmpeg": "^2.1.2",
    "form-data": "^4.0.0",
    "jimp": "^0.22.10",
    "node-fetch": "^2.7.0",
    "screenshot-desktop": "^1.15.0",
    "tesseract.js": "^5.0.4"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1"
  }
}
